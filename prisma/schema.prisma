generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Example {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  value       Float    @default(0.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique @db.VarChar(50)
  email       String   @unique @db.VarChar(100)
  hashedPassword   String  @db.VarChar(255)
  phone       String?  @db.VarChar(15)
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  devices      Device[]
  notifications Notification[]

  @@map("users")
}

enum DeviceType {
  TEMPERATURE_SENSOR
  SOIL_SENSOR
  LIGHT_SENSOR
  PUMP
  LED
  LCD
}

model Device {
  id   Int        @id @default(autoincrement())
  userId     Int
  deviceName String     @db.VarChar(100)
  deviceType DeviceType
  location    String?    @db.VarChar(100)
  createdAt  DateTime   @default(now()) @db.Timestamp(6)

  user        User      @relation(fields: [userId], references: [id])
  sensorData SensorData[]
  pumpControls PumpControl[]
  rgbControls RGBControl[]
  displayLogs    DisplayLog[]

  @@index([userId])
  @@index([deviceType])
  @@index([location])
  @@map("devices")
}

enum DataType {
  temperature
  humidity
  soil
  light
}

model SensorData {
  id        Int      @id @default(autoincrement())
  deviceId      Int
  dataType      DataType
  value      Float
  recordedAt    DateTime @db.Timestamp(6)

  device         Device   @relation(fields: [deviceId], references: [id])

  alerts         Alert[] 

  @@index([dataType])
  @@index([recordedAt])
  @@index([deviceId, dataType, recordedAt])
  @@map("sensor_data")
}

model DisplayLog {
  id        Int @id @default(autoincrement())
  deviceId Int
  content   String @db.VarChar(32)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  device    Device     @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@map("display_log")
}

model RGBControl {
  id        Int @id @default(autoincrement())
  deviceId Int
  isOn    Boolean  @default(false)
  value     String // JSON (RGB, etc)
  updatedAt DateTime @default(now()) @db.Timestamp(6)

  device    Device     @relation(fields: [deviceId], references: [id])

  @@index([deviceId, updatedAt])
  @@index([isOn])
  @@map("rgb_control")
}

model PumpControl {
  id   Int        @id @default(autoincrement())
  deviceId Int
  isOn    Boolean  @default(false)
  reason    String?    @db.Text
  updatedAt DateTime   @default(now()) @db.Timestamp(6)

  device    Device     @relation(fields: [deviceId], references: [id])

  @@index([deviceId, updatedAt])
  @@index([isOn])
  @@map("pump_control")
}

enum AlertType {
  HIGH_TEMP
  LOW_HUMIDITY
  ERROR
}

model Alert {
  id    Int       @id @default(autoincrement())
  alertType  AlertType
  message     String    @db.Text
  triggeredAt DateTime @default(now()) @db.Timestamp(6)

  sensorDataId Int?     
  sensorData   SensorData? @relation(fields: [sensorDataId], references: [id]) 
  
  @@index([sensorDataId, triggeredAt])
  @@map("alerts")
}

model Notification {
  id Int                 @id @default(autoincrement())
  userId         Int
  message        String              @db.Text
  isRead         Boolean  @default(false)
  sentAt         DateTime            @default(now()) @db.Timestamp(6)

  user            User                @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([sentAt])
  @@map("notifications")
}